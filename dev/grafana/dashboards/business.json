{
  "title": "EarlyPass — Business",
  "uid": "earlypass-business",
  "time": {"from": "now-24h", "to": "now"},
  "refresh": "1m",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Active Campaigns",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "earlypass_active_campaigns", "legendFormat": "campaigns"}]
    },
    {
      "id": 2, "type": "stat", "title": "Outbox Pending",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "earlypass_outbox_pending", "legendFormat": "pending"}]
    },
    {
      "id": 3, "type": "timeseries", "title": "Signups / hour",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "rate(earlypass_signups_total[1h]) * 3600", "legendFormat": "{{source}}"}]
    },
    {
      "id": 4, "type": "timeseries", "title": "Email Verifications / hour",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "rate(earlypass_email_verifications_total[1h]) * 3600", "legendFormat": "{{source}}"}]
    },
    {
      "id": 5, "type": "timeseries", "title": "Referral Conversions / hour",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [{"expr": "rate(earlypass_referral_conversions_total[1h]) * 3600", "legendFormat": "{{campaign_id}}"}]
    },
    {
      "id": 6, "type": "timeseries", "title": "Invites Sent & Redeemed / hour",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(earlypass_invites_sent_total[1h]) * 3600", "legendFormat": "sent"},
        {"expr": "rate(earlypass_invite_redeems_total[1h]) * 3600", "legendFormat": "redeemed"}
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Email Sent / hour (by status)",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "targets": [{"expr": "rate(earlypass_email_sent_total[1h]) * 3600", "legendFormat": "{{status}}"}]
    },
    {
      "id": 8, "type": "timeseries", "title": "Fraud Blocks / hour",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "targets": [{"expr": "rate(earlypass_fraud_blocks_total[1h]) * 3600", "legendFormat": "{{reason}}"}]
    }
  ]
}
