{
  "title": "EarlyPass — System",
  "uid": "earlypass-system",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Request Rate (req/s)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "rate(earlypass_http_server_request_duration_seconds_count[1m])", "legendFormat": "{{http_route}}"}]
    },
    {
      "id": 2, "type": "timeseries", "title": "HTTP 5xx Error Rate",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "rate(earlypass_http_server_request_duration_seconds_count{http_response_status_code=~'5..'}[5m])", "legendFormat": "5xx"}]
    },
    {
      "id": 3, "type": "timeseries", "title": "Latency p50 / p95 / p99 (ms)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(earlypass_http_server_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(earlypass_http_server_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(earlypass_http_server_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p99"}
      ]
    },
    {
      "id": 4, "type": "timeseries", "title": "Webhook Deliveries / hour",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [{"expr": "rate(earlypass_webhook_deliveries_total[1h]) * 3600", "legendFormat": "{{status}}"}]
    },
    {
      "id": 5, "type": "timeseries", "title": "Magic Link Requests / hour",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [{"expr": "rate(earlypass_auth_magic_link_requests_total[1h]) * 3600", "legendFormat": "{{result}}"}]
    },
    {
      "id": 6, "type": "timeseries", "title": "Go Goroutines",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [{"expr": "earlypass_process_runtime_go_goroutines", "legendFormat": "goroutines"}]
    },
    {
      "id": 7, "type": "timeseries", "title": "Go Heap Alloc (MB)",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "targets": [{"expr": "earlypass_process_runtime_go_mem_heap_alloc_bytes / 1024 / 1024", "legendFormat": "heap MB"}]
    }
  ]
}
