{
  "title": "EarlyPass — API",
  "uid": "earlypass-api",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Request Rate (req/s)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "rate(http_server_request_duration_seconds_count[1m])", "legendFormat": "{{http_route}}"}]
    },
    {
      "id": 2, "type": "timeseries", "title": "Latency p95 (ms)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, rate(http_server_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p95"}]
    },
    {
      "id": 3, "type": "timeseries", "title": "HTTP 5xx Error Rate",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [{"expr": "rate(http_server_request_duration_seconds_count{http_response_status_code=~'5..'}[5m])", "legendFormat": "5xx"}]
    },
    {
      "id": 4, "type": "timeseries", "title": "Latency p50 / p99 (ms)",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(http_server_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.99, rate(http_server_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p99"}
      ]
    }
  ]
}
