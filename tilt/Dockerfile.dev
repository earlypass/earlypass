# Stage 1: Build the dashboard JS bundle with inline source maps.
FROM node:22-alpine AS js-builder
WORKDIR /app
COPY dashboard/package*.json dashboard/
RUN cd dashboard && npm ci
COPY dashboard/ dashboard/
# Outputs to /app/internal/dashboard/static/ (mirrors the repo path layout).
RUN cd dashboard && node scripts/build.js --dev

# Stage 2: Build the Go binary with the fresh JS embedded.
FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# Overwrite the pre-committed static assets with the dev build (includes source maps).
COPY --from=js-builder /app/internal/dashboard/static/ ./internal/dashboard/static/
RUN CGO_ENABLED=0 go build -o /server ./cmd/server

FROM alpine:3.21
COPY --from=builder /server /server
EXPOSE 3000
CMD ["/server"]
